# PARA Production Environment Variables
# Copy to .env and fill in ALL values before launching.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

POSTGRES_USER=pg
POSTGRES_PASSWORD=<32-char-random-hex>
POSTGRES_DB=para

# =============================================================================
# PDS (Personal Data Server) — para-pds container
# =============================================================================

PDS_HOSTNAME=pds.para.social
PDS_PORT=2583

# Database (PostgreSQL required for production)
PDS_DB_POSTGRES_URL=postgres://pg:<password>@postgres:5432/para

# Blob storage
PDS_BLOBSTORE_DISK_LOCATION=/data/blobs

# Signing keys — generate with: openssl rand -hex 32
PDS_REPO_SIGNING_KEY_K256_PRIVATE_KEY_HEX=
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=

# Secrets — high-entropy, rotate regularly
PDS_DPOP_SECRET=
PDS_JWT_SECRET=
PDS_ADMIN_PASSWORD=<strong-admin-password>

# External services
PDS_DID_PLC_URL=https://plc.directory
PDS_BSKY_APP_VIEW_URL=https://appview.para.social
PDS_BSKY_APP_VIEW_DID=did:web:appview.para.social
PDS_CRAWLERS=https://bsky.network

# Rate limiting
PDS_RATE_LIMITS_ENABLED=true
PDS_RATE_LIMIT_BYPASS_KEY=<random-hex>

# OAuth provider branding
PDS_OAUTH_PROVIDER_NAME="PARA"
PDS_OAUTH_PROVIDER_PRIMARY_COLOR="#48267F"
PDS_OAUTH_PROVIDER_HOME_LINK=https://para.social
PDS_OAUTH_PROVIDER_TOS_LINK=https://para.social/tos
PDS_OAUTH_PROVIDER_POLICY_LINK=https://para.social/privacy

# Registration
PDS_INVITE_REQUIRED=1

# =============================================================================
# AppView (bsky) — para-bsky container
# =============================================================================

BSKY_SERVER_DID=did:web:appview.para.social
ADMIN_PASSWORDS=<comma-separated-passwords>
ADMIN_DIDS=<comma-separated-admin-dids>

# Internal service mesh
DATAPLANE_URLS=http://dataplane:2585
BSYNC_URL=http://bsync:2586

# =============================================================================
# Ozone (Moderation) — para-ozone container
# =============================================================================

OZONE_SERVER_DID=did:web:ozone.para.social
OZONE_ADMIN_DIDS=<comma-separated-admin-dids>

# =============================================================================
# bsync — para-bsync container
# =============================================================================

BSYNC_SERVER_DID=did:web:bsync.para.social

# =============================================================================
# PARA Frontend (mobile app build-time vars)
# =============================================================================

# Expo / EAS
EXPO_PUBLIC_ENV=production
EXPO_PUBLIC_DEFAULT_SERVICE=https://pds.para.social
EXPO_PUBLIC_RELEASE_VERSION=1.0.0

# Sentry (crash reporting)
SENTRY_AUTH_TOKEN=<sentry-auth-token>
SENTRY_ORG=<sentry-org>
SENTRY_PROJECT=<sentry-project>

# Google Maps (required for geolocation features)
GOOGLE_MAPS_IOS_API_KEY=<google-maps-ios-key>
GOOGLE_MAPS_ANDROID_API_KEY=<google-maps-android-key>

# =============================================================================
# OPTIONAL / ADVANCED
# =============================================================================

# Feed generator (post-launch)
# FEEDGEN_DID=did:web:feeds.para.social
# FEEDGEN_HOST=https://feeds.para.social

# PLC directory (only change if self-hosting PLC)
# PLC_HOSTNAME=plc.para.social
