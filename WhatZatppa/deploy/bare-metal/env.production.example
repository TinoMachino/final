# /etc/para/para-backend.env (copy from this file)
# Copy to /etc/para/para-backend.env and fill in ALL values.
# Do not commit real secrets to the repo.
#
# Generate 32-byte hex secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate k256 private keys (same command works for secp256k1 hex):
#   openssl rand -hex 32

NODE_ENV=production
ENV=production

# =============================================================================
# Public identity (must match DNS and Caddy vhosts)
# =============================================================================
DEV_ENV_PDS_HOSTNAME=pds.paramx.social
DEV_ENV_BSKY_PUBLIC_URL=https://appview.paramx.social
DEV_ENV_ENABLE_DID_DOC_WITH_SESSION=true

# =============================================================================
# Local service ports (Caddy proxies these)
# =============================================================================
DEV_ENV_PLC_PORT=2582
DEV_ENV_PDS_PORT=2583
DEV_ENV_BSKY_PORT=2584
DEV_ENV_OZONE_PORT=2587
DEV_ENV_CHAT_PORT=2590
DEV_ENV_INTROSPECT_PORT=2581

# =============================================================================
# Persistent storage (must match ReadWritePaths in systemd unit)
# =============================================================================
DEV_ENV_PDS_DATA_DIRECTORY=/srv/para/pds
DEV_ENV_PDS_BLOBSTORE_DIRECTORY=/srv/para/blobstore
DB_POSTGRES_SCHEMA=production

# =============================================================================
# Infrastructure — Postgres + Redis on this host
# =============================================================================
# Update password to match whatever you set for the 'para' Postgres role.
DB_POSTGRES_URL=postgresql://para:CHANGE_ME@127.0.0.1:5432/para
REDIS_HOST=127.0.0.1:6379

# =============================================================================
# PDS signing keys — generate each with: openssl rand -hex 32
# =============================================================================
PDS_REPO_SIGNING_KEY_K256_PRIVATE_KEY_HEX=CHANGE_ME
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=CHANGE_ME

# =============================================================================
# PDS secrets — generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
PDS_JWT_SECRET=CHANGE_ME
PDS_DPOP_SECRET=CHANGE_ME
PDS_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PDS_RATE_LIMIT_BYPASS_KEY=CHANGE_ME

# =============================================================================
# PDS registration control
# =============================================================================
# Set to 1 to require invite codes (recommended for public launch).
DEV_ENV_SKIP_MOCK_SETUP=1
DEV_ENV_SKIP_PARA_DEMO_SEED=1
PDS_INVITE_REQUIRED=1

# =============================================================================
# AppView
# =============================================================================
BSKY_SERVER_DID=did:web:appview.paramx.social
ADMIN_PASSWORDS=CHANGE_ME
ADMIN_DIDS=

# =============================================================================
# Ozone (moderation)
# =============================================================================
OZONE_SERVER_DID=did:web:ozone.paramx.social
OZONE_ADMIN_DIDS=

# =============================================================================
# OAuth provider branding
# =============================================================================
PDS_OAUTH_PROVIDER_NAME="PARA"
PDS_OAUTH_PROVIDER_PRIMARY_COLOR="#48267F"
PDS_OAUTH_PROVIDER_HOME_LINK=https://web.paramx.social
PDS_OAUTH_PROVIDER_TOS_LINK=https://web.paramx.social/tos
PDS_OAUTH_PROVIDER_POLICY_LINK=https://web.paramx.social/privacy

# =============================================================================
# External upstreams
# =============================================================================
PDS_DID_PLC_URL=https://plc.directory
PDS_CRAWLERS=https://bsky.network

# =============================================================================
# Optional: Rolodex / feed generator (post-launch)
# =============================================================================
# BSKY_ROLODEX_URL=
# FEEDGEN_DID=did:web:feeds.paramx.social
