# /etc/para/bskyweb.env (copy from this file)
# Copy to /etc/para/bskyweb.env and edit.
# Do not commit real secrets to the repo.
#
# The bskyweb binary is built from PARA/bskyweb/ and started by
# para-bskyweb.service on port 8100, behind Caddy at web.paramx.social.

# Listening address for the bskyweb HTTP server.
BSKYWEB_HTTP_ADDRESS=:8100

# Where bskyweb should point users for their PDS (sign-in).
ATP_PDS_HOST=https://pds.paramx.social

# AppView (bsky) used for public feed queries.
ATP_APPVIEW_HOST=https://appview.paramx.social
BSKYWEB_APPVIEW_HOST=https://appview.paramx.social

# Public-facing base URL of this web frontend.
BSKYWEB_PUBLIC_URL=https://web.paramx.social

# Go env: disable CGO if you compiled bskyweb with CGO_ENABLED=0
# (not needed if built normally, but useful for debugging linker issues).
# CGO_ENABLED=0

# Optional: OAuth session DB location (defaults to ./oauth_sessions.db)
# BSKYWEB_OAUTH_DB_PATH=/srv/para/bskyweb-sessions.db
