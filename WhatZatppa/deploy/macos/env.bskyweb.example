# ~/para/bskyweb.env
# Copy: cp WhatZatppa/deploy/macos/env.bskyweb.example ~/para/bskyweb.env

BSKYWEB_HTTP_ADDRESS=:8100

# While testing locally:
ATP_PDS_HOST=http://localhost:2583
ATP_APPVIEW_HOST=http://localhost:2584
BSKYWEB_APPVIEW_HOST=http://localhost:2584
BSKYWEB_PUBLIC_URL=http://localhost:8100

